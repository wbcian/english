# macOS
.DS_Store

# Claude Code per-machine settings (local permissions etc.)
.claude/settings.local.json

# Claude Code per-session worktrees
.claude/worktrees/

# Claude Code session state (do not push)
.claude/

# Superpowers visual brainstorming state (local preview server)
/.superpowers/

# Node
node_modules/

# Env files
.env
.env.*

# Logs
*.log

# Editors
.vscode/
.idea/

# Podcast pipeline: large/binary artifacts (transcripts/*.txt are committed)
transcripts/.cache/
tools/models/
*.mp3
*.wav

# Exception: app pre-generated Edge TTS audio is content-addressable and
# committed so deploys don't depend on the Edge TTS service being reachable.
!app/public/audio/*.mp3

# Clips belonging to private, locally-excluded lessons (see .git/info/exclude).
# They have to be listed here rather than there, because the un-ignore above
# outranks $GIT_DIR/info/exclude. Audio is content-addressed, so a hash is the
# only way to name one; these carry no text and are already derivable as the
# manifest hashes with no committed mp3. Regenerate: `npm --prefix app run audio:gen:all`.
