---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import LevelBadge from '../../components/LevelBadge.astro';
import FrequencyBadge from '../../components/FrequencyBadge.astro';
import { CEFR_HEDGE_NOTE, CEFR_INFO } from '../../data/cefr';
import { FREQUENCY_INFO } from '../../data/frequency';

export async function getStaticPaths() {
  const entries = await getCollection('vocab');
  return entries.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

type Props = { entry: CollectionEntry<'vocab'> };
const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const {
  word, phonetic, pos, zh, cefr, frequency, proficiency,
  first_seen, last_reviewed, review_count, tags, source,
} = entry.data;

const proficiencyStars =
  typeof proficiency === 'number'
    ? '★'.repeat(Math.min(5, Math.max(0, proficiency))) + '☆'.repeat(Math.max(0, 5 - proficiency))
    : null;

const lastReviewed = last_reviewed?.toISOString().slice(0, 10);
const firstSeen = first_seen?.toISOString().slice(0, 10);
---

<Layout title={`${word} · Vocab`}>
  <article class="vocab">
    <header class="vocab-header">
      <h1 class="word speakable-word">{word}</h1>
      {phonetic && <span class="phonetic">{phonetic}</span>}
      {pos && <span class="pos">{pos}</span>}
      {(cefr || frequency) && (
        <span class="badges">
          {cefr && <LevelBadge level={cefr.level} hedged={cefr.hedged} />}
          {frequency && <FrequencyBadge frequency={frequency} />}
        </span>
      )}
      <p class="zh">{zh}</p>
    </header>

    <dl class="meta">
      {cefr && (
        <>
          <dt>級別</dt>
          <dd>
            {/* 兩條軸分行寫。擠成一行時 CEFR 的白話和常見度的白話會黏成一串看不懂 */}
            <span class="axis"><span class="axis-label">難度</span>{CEFR_INFO[cefr.level].zh}</span>
            {frequency && (
              <span class="axis"><span class="axis-label">常見度</span>{FREQUENCY_INFO[frequency].goal}</span>
            )}
            {cefr.hedged && <span class="hedge-note">{CEFR_HEDGE_NOTE}</span>}
          </dd>
        </>
      )}
      {proficiencyStars && (
        <>
          <dt>熟練度</dt>
          <dd class="proficiency">{proficiencyStars}</dd>
        </>
      )}
      {firstSeen && (
        <>
          <dt>首次接觸</dt>
          <dd>{firstSeen}</dd>
        </>
      )}
      {lastReviewed && (
        <>
          <dt>上次複習</dt>
          <dd>{lastReviewed}{review_count && review_count > 1 ? ` (${review_count} 次)` : ''}</dd>
        </>
      )}
      {tags && tags.length > 0 && (
        <>
          <dt>Tags</dt>
          <dd class="tags">{tags.map(t => <span class="tag">{t}</span>)}</dd>
        </>
      )}
      {source && (
        <>
          <dt>來源</dt>
          <dd class="source">{source}</dd>
        </>
      )}
    </dl>

    <Content />
  </article>
</Layout>

<script>
  import '../../scripts/speech';
</script>

<style>
  .vocab-header {
    border-bottom: 1px solid var(--card-border);
    padding-bottom: 12px;
    margin-bottom: 16px;
  }
  .word {
    font-size: 2.4rem;
    line-height: 1.15;
    margin: 0 0 6px 0;
    display: inline;
    border-bottom: 0;
    padding-bottom: 0;
  }
  .phonetic {
    color: var(--fg-muted);
    margin-left: 14px;
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 1.1rem;
  }
  /* .badges 跟著 .pos 走同一條基線，讓 word / 音標 / 詞性 / 難度 badge 排成一列 */
  .pos,
  .badges {
    margin-left: 10px;
    vertical-align: 0.25em;
  }
  .pos {
    background: var(--pill-bg);
    color: var(--pill-fg);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.78em;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }
  .badges {
    display: inline-flex;
    gap: 6px;
  }
  .zh {
    font-size: 1.15em;
    color: var(--fg);
    margin: 8px 0 0;
    font-weight: 500;
  }
  .axis { display: block; }
  .axis-label,
  .hedge-note {
    color: var(--fg-muted);
    font-size: 0.88em;
  }
  .axis-label {
    display: inline-block;
    min-width: 4em;
  }
  .hedge-note {
    display: block;
    margin-top: 2px;
  }
  .meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 4px 16px;
    margin: 1em 0 1.6em;
    font-size: 0.92em;
  }
  .meta dt {
    color: var(--fg-muted);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.78em;
    letter-spacing: 0.06em;
    padding-top: 2px;
  }
  .meta dd {
    margin: 0;
    color: var(--fg);
  }
  .meta .proficiency {
    color: var(--accent);
    letter-spacing: 0.05em;
  }
  .tag {
    display: inline-block;
    background: var(--card-border);
    padding: 1px 8px;
    border-radius: 4px;
    margin-right: 4px;
    margin-bottom: 4px;
    font-size: 0.85em;
  }
  .source {
    color: var(--fg-muted);
    font-size: 0.92em;
  }
  article.vocab { padding-bottom: 4em; }
</style>
