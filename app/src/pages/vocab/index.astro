---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import VocabList from '../../components/VocabList.astro';

const all = await getCollection('vocab');
if (all.length === 0) {
  throw new Error("Empty 'vocab' collection — check glob base path in src/content.config.ts");
}

const entries = all.slice().sort((a, b) => {
  const pa = a.data.proficiency ?? 0;
  const pb = b.data.proficiency ?? 0;
  if (pa !== pb) return pa - pb;
  const da = a.data.last_reviewed?.getTime() ?? 0;
  const db = b.data.last_reviewed?.getTime() ?? 0;
  return da - db;
});
---

<Layout title="Vocabulary">
  <h1>Vocabulary</h1>
  <p class="intro">{entries.length} entries · 由 ★ 低到高（最該複習在最上）· 點單字直接朗讀</p>
  <VocabList entries={entries} />
</Layout>

<script>
  import '../../scripts/speech';
</script>

<style>
  .intro {
    color: var(--fg-muted);
    font-size: 0.95em;
    margin: 0 0 1em;
  }
</style>
