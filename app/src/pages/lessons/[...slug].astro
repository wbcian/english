---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import LevelBadge from '../../components/LevelBadge.astro';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

type Props = { entry: CollectionEntry<'lessons'> };
const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const { date, topic, series, part, level } = entry.data;
const dateStr = date.toISOString().slice(0, 10);
---

<Layout title={`${topic} · English Lessons`}>
  <article>
    <div class="lesson-meta">
      <time>{dateStr}</time>
      {level && <LevelBadge level={level} showToeic />}
      {series && part != null && <span class="badge">{series} · Part {part}</span>}
    </div>
    <Content />
  </article>
</Layout>

<script>
  import '../../scripts/speech';
</script>

<style>
  .lesson-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.88em;
    color: var(--fg-muted);
    margin-bottom: 8px;
  }
  .badge {
    background: var(--pill-bg);
    color: var(--pill-fg);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.9em;
  }
  article { padding-bottom: 4em; }
</style>
