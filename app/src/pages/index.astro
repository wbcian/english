---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import LessonsList from '../components/LessonsList.astro';
import VocabList from '../components/VocabList.astro';

const lessons = await getCollection('lessons');
const vocab = await getCollection('vocab');
if (lessons.length === 0) {
  throw new Error("Empty 'lessons' collection — check glob base path");
}

// Series-aware ordering: keep every part of a series contiguous (Part 1→2→3),
// and float each series block to its most-recent member's date so recent series
// still sort near the top. Standalone lessons sort by their own date.
type LessonEntry = (typeof lessons)[number];
const seriesMaxDate = new Map<string, number>();
for (const l of lessons) {
  if (!l.data.series) continue;
  const t = l.data.date.getTime();
  seriesMaxDate.set(l.data.series, Math.max(seriesMaxDate.get(l.data.series) ?? 0, t));
}
const groupDate = (l: LessonEntry) =>
  l.data.series ? seriesMaxDate.get(l.data.series)! : l.data.date.getTime();
const groupKey = (l: LessonEntry) => l.data.series ?? l.id;

const sortedLessons = lessons.sort((a, b) => {
  const dt = groupDate(b) - groupDate(a); // group date desc
  if (dt !== 0) return dt;
  if (groupKey(a) !== groupKey(b)) return groupKey(a) < groupKey(b) ? -1 : 1; // keep series together
  return (a.data.part ?? 0) - (b.data.part ?? 0); // within series: part asc
});

const sortedVocab = vocab.slice().sort((a, b) => {
  const pa = a.data.proficiency ?? 0;
  const pb = b.data.proficiency ?? 0;
  if (pa !== pb) return pa - pb;
  const da = a.data.last_reviewed?.getTime() ?? 0;
  const db = b.data.last_reviewed?.getTime() ?? 0;
  return da - db;
});
---

<Layout title="English">
  <div class="tabs">
    <input type="radio" name="tab" id="tab-lessons" class="tab-radio" checked />
    <input type="radio" name="tab" id="tab-vocab" class="tab-radio" />

    <div class="tab-bar" role="tablist">
      <label for="tab-lessons" class="tab-label" id="label-lessons">
        Lessons <span class="count">{sortedLessons.length}</span>
      </label>
      <label for="tab-vocab" class="tab-label" id="label-vocab">
        Vocabulary <span class="count">{sortedVocab.length}</span>
      </label>
    </div>

    <section class="tab-panel panel-lessons" id="panel-lessons">
      <p class="intro">點段落或單字朗讀</p>
      <LessonsList entries={sortedLessons} />
    </section>

    <section class="tab-panel panel-vocab" id="panel-vocab">
      <p class="intro">由 ★ 低到高（最該複習在最上）· 點單字直接朗讀</p>
      <VocabList entries={sortedVocab} />
    </section>
  </div>
</Layout>

<script>
  import '../scripts/speech';
</script>

<script>
  // Sync tab state with URL hash so #lessons / #vocab can deep-link.
  const HASH_TO_TAB: Record<string, string> = {
    '#lessons': 'tab-lessons',
    '#vocab': 'tab-vocab',
  };
  const TAB_TO_HASH: Record<string, string> = {
    'tab-lessons': '#lessons',
    'tab-vocab': '#vocab',
  };

  function syncFromHash() {
    const id = HASH_TO_TAB[location.hash];
    if (!id) return;
    const el = document.getElementById(id) as HTMLInputElement | null;
    if (el) el.checked = true;
  }

  window.addEventListener('hashchange', syncFromHash);
  document.querySelectorAll<HTMLInputElement>('.tab-radio').forEach((radio) => {
    radio.addEventListener('change', () => {
      const newHash = TAB_TO_HASH[radio.id];
      if (newHash && location.hash !== newHash) {
        history.replaceState(null, '', newHash);
      }
    });
  });
  syncFromHash();
</script>

<style>
  /* Hide radios; labels become tab buttons */
  .tab-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .tab-bar {
    display: flex;
    gap: 4px;
    border-bottom: 1px solid var(--card-border);
    margin-bottom: 1em;
  }
  .tab-label {
    padding: 10px 16px;
    cursor: pointer;
    color: var(--fg-muted);
    font-weight: 500;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    margin-bottom: -1px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .tab-label:hover { color: var(--fg); }
  .count {
    background: var(--card-border);
    color: var(--fg-muted);
    padding: 1px 7px;
    border-radius: 999px;
    font-size: 0.78em;
    font-weight: 600;
  }
  #tab-lessons:checked ~ .tab-bar #label-lessons,
  #tab-vocab:checked ~ .tab-bar #label-vocab {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  #tab-lessons:checked ~ .tab-bar #label-lessons .count,
  #tab-vocab:checked ~ .tab-bar #label-vocab .count {
    background: var(--speak-highlight);
    color: var(--fg);
  }
  @media (prefers-color-scheme: dark) {
    #tab-lessons:checked ~ .tab-bar #label-lessons .count,
    #tab-vocab:checked ~ .tab-bar #label-vocab .count { color: var(--accent); }
  }

  .tab-panel { display: none; }
  #tab-lessons:checked ~ .panel-lessons { display: block; }
  #tab-vocab:checked ~ .panel-vocab { display: block; }

  .intro {
    color: var(--fg-muted);
    font-size: 0.95em;
    margin: 0 0 1em;
  }

  /* Focus styles for keyboard accessibility */
  .tab-radio:focus-visible + .tab-label,
  .tab-radio:focus-visible ~ .tab-bar .tab-label {
    /* Visible focus ring approximation */
  }
  .tab-label:focus-within { outline: 2px solid var(--accent); outline-offset: 2px; }
</style>
