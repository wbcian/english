---
import type { CollectionEntry } from 'astro:content';
import LevelBadge from './LevelBadge.astro';

interface Props {
  entry: CollectionEntry<'lessons'>;
}
const { entry } = Astro.props;
const { date, topic, source, series, part, level, title_zh, title_en } = entry.data;
const dateStr = date.toISOString().slice(0, 10);
const firstSentence = source.split(/[.。?!]/)[0]?.trim() ?? source;
const href = `${import.meta.env.BASE_URL}lessons/${entry.id}/`.replace(/\/+/g, '/');
const displayTitle = title_zh ?? topic;
---

<a class="lesson-card" href={href} data-id={entry.id}>
  <div class="meta">
    <time>{dateStr}</time>
    {level && <LevelBadge level={level} />}
    {series && part != null && <span class="badge">{series} · Part {part}</span>}
  </div>
  <h2 class="topic">{displayTitle}</h2>
  {title_zh && title_en && <p class="title-en">{title_en}</p>}
  <p class="source">{firstSentence}</p>
</a>

<style>
  .lesson-card {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 10px;
    padding: 16px 20px;
    margin: 12px 0;
    text-decoration: none;
    color: var(--fg);
    transition: border-color 0.2s, transform 0.1s;
  }
  .lesson-card:hover {
    border-color: var(--accent);
    text-decoration: none;
  }
  .lesson-card:active { transform: scale(0.997); }
  .meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 0.85em;
    color: var(--fg-muted);
    margin-bottom: 4px;
  }
  .badge {
    background: var(--pill-bg);
    color: var(--pill-fg);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.85em;
  }
  .topic {
    font-size: 1.15rem;
    margin: 4px 0 2px;
    border-bottom: 0;
    padding-bottom: 0;
    color: var(--fg);
  }
  .title-en {
    font-size: 0.85em;
    color: var(--fg-muted);
    margin: 0 0 6px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .source {
    font-size: 0.92em;
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
