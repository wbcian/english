---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'lessons'>;
}
const { entry } = Astro.props;
const { date, topic, source, series, part } = entry.data;
const dateStr = date.toISOString().slice(0, 10);
const firstSentence = source.split(/[.。?!]/)[0]?.trim() ?? source;
const href = `${import.meta.env.BASE_URL}lessons/${entry.id}/`.replace(/\/+/g, '/');
---

<a class="lesson-card" href={href}>
  <div class="meta">
    <time>{dateStr}</time>
    {series && part != null && <span class="badge">{series} · Part {part}</span>}
  </div>
  <h2 class="topic">{topic}</h2>
  <p class="source">{firstSentence}</p>
</a>

<style>
  .lesson-card {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 10px;
    padding: 16px 20px;
    margin: 12px 0;
    text-decoration: none;
    color: var(--fg);
    transition: border-color 0.2s, transform 0.1s;
  }
  .lesson-card:hover {
    border-color: var(--accent);
    text-decoration: none;
  }
  .lesson-card:active { transform: scale(0.997); }
  .meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 0.85em;
    color: var(--fg-muted);
    margin-bottom: 4px;
  }
  .badge {
    background: var(--speak-highlight);
    color: var(--fg);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.85em;
  }
  @media (prefers-color-scheme: dark) {
    .badge { color: var(--accent); }
  }
  .topic {
    font-size: 1.15rem;
    margin: 4px 0 6px;
    border-bottom: 0;
    padding-bottom: 0;
    color: var(--fg);
  }
  .source {
    font-size: 0.92em;
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
