---
import { FREQUENCY_INFO, type FrequencyTier } from '../data/frequency';

interface Props {
  frequency: FrequencyTier;
}
const { frequency } = Astro.props;
const info = FREQUENCY_INFO[frequency];
---

<span class="freq-badge" title={info.goal}>{info.zh}</span>

<style>
  /* 刻意保持樸素：常見度是輔助資訊，難度 badge 才是視覺重點。所以不給底色、
     不加粗、不用顏色分級——純文字一個詞就夠讀。 */
  .freq-badge {
    color: var(--fg-muted);
    font-size: 0.85em;
    white-space: nowrap;
  }
</style>
