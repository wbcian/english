flowchart TB
  subgraph Content["CONTENT — author writes .md"]
    direction LR
    L["<b>lessons/*.md</b><br/>8 files<br/><i style='color:#666;font-size:0.85em'>course notes (英文 transcript + vocab tables)</i>"]
    V["<b>vocab/*.md</b><br/>74 files<br/><i style='color:#666;font-size:0.85em'>單字詳細卡 (Examples / Encounters)</i>"]
